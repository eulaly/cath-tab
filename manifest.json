{
  "manifest_version": 3,
  "name": "Catholic New Tab",
    "version": "0.2.0",
  "description": "Replace New Tab with daily Bible verse.",
  "permissions": ["storage"],
  "host_permissions": [
	"https://www.biblegateway.com/*"
  ],
  "chrome_url_overrides": {
	"newtab": "newtab.html"
    },
  "browser_specific_settings": {
      "gecko": {
	  "id": "catholic-new-tab@example.org",
	  "data_collection_permissions": {
	      "required": ["none"]
	  }
      }
  }
}
